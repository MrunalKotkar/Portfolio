# Copy this file to .env.local and fill in your values.
# .env.local is gitignored so your secrets stay private.

# Formspree endpoint for the contact form.
# 1. Sign up free at https://formspree.io
# 2. Create a new form → copy the endpoint URL (e.g. https://formspree.io/f/xayjkzpq)
# 3. Paste it below in your .env.local
VITE_FORMSPREE_URL=
